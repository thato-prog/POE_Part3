<Window x:Class="POE_Part3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POE_Part3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <!--
            HOME GRID
            This grid serves as the main landing page  of the application.
            It contains a logo for AI , a welcome message to greet users,
            and a navigation button to proceed to the next section.
            Currently hidden by default.
        -->
        <Grid x:Name="home_grid" Visibility="Visible" Background="Black">

            <!-- Logo -->
            <Image
                Source="/logo3.png"
                Height="200"
                Width="300"
                Margin="0,0,0,200"
                   />
            <!-- welcome message-->
            <TextBlock
                Text="Welcome to AskMe , click  Start AskMe to continue"
                Height="20"
                Width="270"
                TextAlignment="Center"
                Margin="0,30,0,0"
                FontFamily="Arial Rounded MT Bold"
                Foreground="HotPink"
                FontSize="10"
                />

            <!-- button to continue-->
            <Button
                Height="40"
                Width="300"
                Margin="0,200,0,0"
                Content="Start AskMe"
                Click="proceed"
                Background="HotPink"
                Foreground="White"
                BorderBrush="HotPink"
                FontWeight="Bold"
                />

        </Grid>

        <!--
            USERNAME GRID
            This grid is for prompting the user for username.
            It contains a logo for AI, a textbox for users to enter their name,
            and a submit button to save the username.
            Hidden .
        -->
        <Grid x:Name="username_grid" Visibility="Hidden" Background="Black">


            <!-- Logo -->
            <Image
                Source="/logo3.png"
                Height="200"
                Width="300"
                Margin="0,0,0,200"
                   />
            <!-- Hint message-->
            <TextBlock
                Text="Enter username"
                Height="20"
                Width="270"
                TextAlignment="Justify"
                Margin="0,30,0,0"
                FontFamily="Arial Rounded MT Bold"
                />

            <!-- Enter/Prompt username-->
            <TextBox
                Height="40"
                Width="270"
                TextAlignment="Center"
                Margin="0,100,0,0"
                FontFamily="Arial Rounded MT Bold"
                x:Name="usernames_input"
                />

            <!-- error message-->
            <TextBlock
         Text="please enter username to continue..."
         Height="20"
         Width="270"
         TextAlignment="Justify"
         Margin="0,180,0,0"
         Foreground="Red"
         FontFamily="Arial Rounded MT Bold"
         />

            <!-- button to submit name-->
            <Button
         Height="40"
         Width="270"
         Margin="0,250,0,0"
         Content="submit username"
         Click="submit_name"
         Background="HotPink"
         Foreground="White"
         BorderBrush="HotPink"
         FontWeight="Bold"
        />

        </Grid>

        <!--
            CHAT GRID
            This grid handles all messaging and conversation-related features of the application.
            It contains a ListView to display chat messages, a textbox for typing questions,
            and a submit button to send the question to the chat.
            Starting in a hidden state.
        -->

        <!-- Main application page, initially hidden -->
        <Grid Height="450" Width="800"
        x:Name="MainPage"
        Visibility="Hidden" Background="Black">

            <!-- Right-side vertical menu bar -->
            <Grid Margin="595,0,0,0"
            Background="Black"
            Width="215">

                <!-- StackPanel containing menu buttons -->
                <StackPanel Grid.Column="0" Background="DeepPink"
                      Width="170"
                      Margin="0,0,13,0">
                    <TextBlock Text="Menu" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                    <!-- Menu buttons -->
                    <Button Content="Chats" Margin="0,5" Height="40" Click="chatting" Background="LightPink"/>
                    <Button Content="Tasks Reminders" Margin="0,5" Height="40" Click="reminders" Background="LightPink"/>

                    <Button Content="Activity Log" Margin="0,5" Height="40" Click="activity" Background="LightPink"/>
                    <Button Content="Game" Margin="0,20,0,0" Height="40" Click="game" Background="LightPink"/>
                    <Button Content="Exit" Margin="0,20,0,0" Height="40" Click="exit" Background="LightPink"/>
                </StackPanel>
            </Grid>
            <!-- Chat page - default visible inside main app -->
            <Grid Margin="0,0,205,0"
            x:Name="chat_page"
            Visibility="Visible">

                <!-- ListView to show chat messages -->
                <ListView Margin="20,10,27,101"
                    x:Name="chats"
                          Background="Black"
                          />

                <!-- TextBox to type user's questions -->
                <TextBox Margin="20,356,158,44"
                   x:Name="question"
                   Height="50"
                   Background="DeepPink"
                   Foreground="Black"
                         />

                <!-- Button to submit user's question -->
                <Button Content="ask"
                  Click="send"
                  Height="50"
                  Margin="442,357,27,43"
                  Background="DeepPink"
                  Foreground="Black"
                        />
            </Grid>
            <!-- Reminders page -->
            <Grid Margin="0,0,205,0"
            x:Name="reminderPage"
            Visibility="Hidden">

                <!-- ListView showing reminders, double-click to mark done or delete -->
                <ListView Margin="20,10,27,87"
                    MouseDoubleClick="remind_append_MouseDoubleClick"
                    x:Name="view_tasks" />

                <!-- Instructions for reminders page -->
                <TextBlock Text="All the task will be listed above with their status of done or due, if not then double click to mark done and double click to delete or remove once done."
                     TextAlignment="Center"
                     Margin="20,368,14,36"
                     TextWrapping="Wrap"
                     Foreground="Red" />
            </Grid>










            <!-- History page -->
            <Grid Margin="0,0,205,0"
            x:Name="HistoryPage"
            Visibility="Hidden">

                <!-- ListView to show user's interest history -->
                <ListView Margin="20,10,27,87"
                    MouseDoubleClick="remind_append_MouseDoubleClick"
                    x:Name="history_append" />

                <!-- Instructions for history page -->
                <TextBlock Text="If no history listed then try to add some from the chats , by saying 'im interest then mention your interest there, thank you.'"
                     TextAlignment="Center"
                     Margin="20,368,14,36"
                     TextWrapping="Wrap"
                     Foreground="Red" />
            </Grid>

            <!-- Activity log page -->
            <Grid Margin="0,0,205,0"
            x:Name="LogPage"
            Visibility="Hidden">

                <!-- ListView showing all app activities -->
                <ListView Margin="20,10,27,87"
                    MouseDoubleClick="remind_append_MouseDoubleClick"
                    x:Name="log_append" />

                <!-- Instructions for activity log -->
                <TextBlock Text="All the activities that happens here on the app will be showed here based on what you do or doing."
                     TextAlignment="Center"
                     Margin="20,368,14,36"
                     TextWrapping="Wrap"
                     Foreground="Red" />
            </Grid>

            <!-- Game page for quiz -->
            <Grid Margin="0,0,205,0"
            x:Name="gamePage"
            Visibility="Hidden">

                <!-- Quiz game content -->
                <Grid Height="390px"
                x:Name="quizGame_page"
                Visibility="Visible"
                Margin="10,30,10,30">

                    <!-- Question text -->
                    <TextBlock Height="50px"
                         Width="300px"
                         Text="Question"
                         Foreground="HotPink"
                         TextAlignment="Center"
                         FontSize="20px"
                         x:Name="question_asked"
                         Margin="0,0,0,210" />

                    <!-- Four option buttons for answers -->
                    <Button Height="40px"
                      Width="300px"
                      Background="Gray"
                      Content=""
                      Foreground="Black"
                      FontSize="10px"
                      Margin="0,0,330,120"
                      x:Name="optionButtonOne"
                      Click="optionSelected" />

                    <Button Height="40px"
                      Width="300px"
                      Background="Gray"
                      Content=""
                      Foreground="Black"
                      FontSize="10px"
                      Margin="330,0,0,120"
                      x:Name="optionButtonTwo"
                      Click="optionSelected" />

                    <Button Height="40px"
                      Width="300px"
                      Background="Gray"
                      Content=""
                      Foreground="Black"
                      FontSize="10px"
                      Margin="0,0,330,0"
                      x:Name="optionButtonThree"
                      Click="optionSelected" />

                    <Button Height="40px"
                      Width="300px"
                      Background="Gray"
                      Content=""
                      Foreground="Black"
                      FontSize="10px"
                      Margin="330,0,0,0"
                      x:Name="optionButtonFour"
                      Click="optionSelected" />

                    <!-- Button to submit the answer -->
                    <Button Height="40px"
                      Width="100px"
                      Background="Red"
                      Content="Answer"
                      Foreground="white"
                      HorizontalContentAlignment="Center"
                      Margin="0,140,0,0"
                      Click="answerButton" />

                    <!-- Display for current score -->
                    <TextBlock Height="60px"
                         Width="100px"
                         Text="Score"
                         Foreground="Gray"
                         TextAlignment="Center"
                         FontSize="20px"
                         Margin="-2,6,477,324"
                         x:Name="score_count" />
                </Grid>
            </Grid>
        </Grid>
        <!-- End of main cover grid -->
    </Grid>
</Window>